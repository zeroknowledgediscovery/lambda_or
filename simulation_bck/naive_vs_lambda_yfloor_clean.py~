#!/usr/bin/env python3
import os, argparse
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from scipy.stats import norm

def ensure_dir(d): os.makedirs(d, exist_ok=True)
def expit(x): return 1/(1+np.exp(-x))

def logor_wald(a,b,c,d,ha=0.5):
    a=a.astype(float)+ha; b=b.astype(float)+ha; c=c.astype(float)+ha; d=d.astype(float)+ha
    logor=np.log((a*d)/(b*c))
    se=np.sqrt(1/a + 1/b + 1/c + 1/d)
    z=logor/se
    p=2*norm.sf(np.abs(z))
    return logor,se,p

def volcano(x, p, out_png, title, xlim=(-0.5,0.5), ylim=None):
    y=-np.log10(np.clip(p, 1e-300, 1.0))
    plt.figure(figsize=(8.0,6.0))
    plt.scatter(x, y, s=6, alpha=0.55)
    plt.axvline(0, color="black", lw=1)
    plt.axhline(-np.log10(0.05), color="black", lw=1, ls="--")
    plt.xlim(*xlim)
    if ylim is not None:
        plt.ylim(*ylim)
    plt.xlabel("log(OR)")
    plt.ylabel("-log10(p)")
    plt.title(title)
    plt.tight_layout()
    plt.savefig(out_png, dpi=220)
    plt.close()

def main():
    ap=argparse.ArgumentParser()
    ap.add_argument("--out_dir", type=str, default="./yfloor_clean_demo")
    ap.add_argument("--seed", type=int, default=0)
    ap.add_argument("--m", type=int, default=20000)
    ap.add_argument("--n_case", type=int, default=300000)
    ap.add_argument("--n_ctrl", type=int, default=300000)
    ap.add_argument("--prev0_mean", type=float, default=-3.5)  # less rare, more power
    ap.add_argument("--prev_sd", type=float, default=1.0)
    ap.add_argument("--beta_mean", type=float, default=0.06)    # small but nonzero
    ap.add_argument("--beta_sd", type=float, default=0.03)
    ap.add_argument("--eps", type=float, default=0.03, help="det(K)=p+q-1 ill-conditioning proxy")
    ap.add_argument("--n_val", type=int, default=600, help="validation size driving var_extra")
    ap.add_argument("--var_extra_scale", type=float, default=1.0, help="tune magnitude of extra term")
    ap.add_argument("--xlim", type=float, default=0.35)
    args=ap.parse_args()
    ensure_dir(args.out_dir)
    rng=np.random.default_rng(args.seed)

    m=args.m; n_case=args.n_case; n_ctrl=args.n_ctrl

    # True effects all positive
    beta = np.abs(rng.normal(args.beta_mean, args.beta_sd, size=m))

    # Baseline prevalence in controls
    logit_prev0 = rng.normal(args.prev0_mean, args.prev_sd, size=m)
    prev0 = expit(logit_prev0)
    prev1 = expit(logit_prev0 + beta)

    # True 2x2 counts
    a = rng.binomial(n_case, prev1)  # exposed among cases
    b = rng.binomial(n_ctrl, prev0)  # exposed among ctrls
    c = n_case - a
    d = n_ctrl - b

    log_naive, se_naive, p_naive = logor_wald(a,b,c,d)

    # Manuscript-style extra variance term from (p,q) estimation under ill-conditioning:
    # SE_extra ~ 1/(eps * sqrt(n_val))  => Var_extra ~ 1/(eps^2 * n_val)
    eps = max(float(args.eps), 1e-6)
    var_extra = args.var_extra_scale * (1.0/(eps*eps*max(args.n_val,1)))

    se_lambda = np.sqrt(se_naive**2 + var_extra)
    z_lambda = log_naive / se_lambda
    p_lambda = 2*norm.sf(np.abs(z_lambda))

    # Use same y-limit so contrast is visible
    y_naive = -np.log10(np.clip(p_naive, 1e-300, 1.0))
    y_lambda = -np.log10(np.clip(p_lambda, 1e-300, 1.0))
    ymax = float(np.quantile(y_naive[np.isfinite(y_naive)], 0.995))
    ymax = max(30.0, min(ymax, 500.0))
    xlim = (-args.xlim, args.xlim)

    volcano(log_naive, p_naive, os.path.join(args.out_dir,"volcano_naive.png"),
            f"Naive OR (huge n): median y={np.median(y_naive):.1f}", xlim=xlim, ylim=(0, ymax))
    volcano(log_naive, p_lambda, os.path.join(args.out_dir,"volcano_lambda.png"),
            f"Lambda p-values via SE floor: eps={eps:.3f}, n_val={args.n_val}", xlim=xlim, ylim=(0, ymax))

    df = pd.DataFrame({
        "beta_true": beta,
        "prev0": prev0,
        "prev1": prev1,
        "logOR": log_naive,
        "se_naive": se_naive,
        "p_naive": p_naive,
        "se_lambda": se_lambda,
        "p_lambda": p_lambda,
        "var_extra": var_extra,
        "y_naive": y_naive,
        "y_lambda": y_lambda
    })
    df.to_csv(os.path.join(args.out_dir,"summary.csv"), index=False)

    print(f"var_extra={var_extra:.6g} (SE floor={np.sqrt(var_extra):.4g}), eps={eps}, n_val={args.n_val}")
    print("Wrote:", os.path.abspath(args.out_dir))

if __name__=="__main__":
    main()
