
% ---- file names (change paths if needed) ----
\def\biasfile{Figures/bias.csv}
\def\rmsefile{Figures/rmse.csv}
\def\covfile{Figures/coverage.csv} % uses the name you provided

% labels for the x-axis ticks (row order of the CSVs)
\def\misclabels{0.05,0.10,0.15,0.20}

% read the tables
\pgfplotstableread[col sep=comma]{\biasfile}\biastable
\pgfplotstableread[col sep=comma]{\rmsefile}\rmsetable
\pgfplotstableread[col sep=comma]{\covfile}\covtable


\begin{tikzpicture}
\begin{groupplot}[
  group style = {group size=3 by 1, horizontal sep=48pt, vertical sep=0pt},
  width=0.32\textwidth, height=0.28\textwidth,
  xlabel = {Misclassification rate},
  %xtick=data,
  xticklabels={0,0.05,0.10,0.15,0.20},
  legend style={draw=none, fill=white,at={(2,1.25)}, anchor=south, legend columns=-1, /tikz/every even column/.style={column sep=6pt}},
  legend cell align=left, ylabel style={yshift=-.1in}
]

% -------- Panel 1: Bias --------
\nextgroupplot[very thick,
  ylabel = {Bias},
  title = {\large a.}
]
\addplot+[mark=*, thick] table[x expr=\coordindex, y=bias_n]{\biastable};
\addlegendentry{Naive OR}
\addplot+[mark=square*, thick] table[x expr=\coordindex, y=bias_p]{\biastable};
\addlegendentry{$\SPOR$}

% -------- Panel 2: RMSE --------
\nextgroupplot[very thick,
  ylabel = {RMSE},
  title = {\large b.}
]
\addplot+[mark=*, thick] table[x expr=\coordindex, y=rmse_n]{\rmsetable};
\addplot+[mark=square*, thick] table[x expr=\coordindex, y=rmse_p]{\rmsetable};

% -------- Panel 3: Coverage --------
\nextgroupplot[very thick,
  ylabel = {95\% CI coverage},
  title = {\large c.},
  ymin=0, ymax=1,
  %ytick={0,0.25,0.5,0.75,1.00}
]
\addplot+[mark=*, thick] table[x expr=\coordindex, y=cov_n]{\covtable};
\addplot+[mark=square*, thick] table[x expr=\coordindex, y=cov_p]{\covtable};

\end{groupplot}
\end{tikzpicture}
